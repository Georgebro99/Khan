rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidMessage(data) {
      return data.user is string && data.user.size() > 0 && data.user.size() < 50 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.timestamp is number &&
             data.uid == request.auth.uid;
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
