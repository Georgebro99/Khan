{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "user": {
          "type": "string",
          "description": "The user's display name"
        },
        "text": {
          "type": "string",
          "description": "The message content"
        },
        "timestamp": {
          "type": "number",
          "description": "The time the message was sent"
        },
        "uid": {
          "type": "string",
          "description": "The user's unique ID"
        },
        "reactions": {
          "type": "object",
          "description": "Emoji reactions map (emoji -> list of UIDs)"
        },
        "gif": {
          "type": "string",
          "description": "Optional GIF URL"
        }
      },
      "required": ["user", "text", "timestamp", "uid"]
    },
    "User": {
      "title": "User",
      "description": "A user profile",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "The user's chosen username"
        },
        "email": {
          "type": "string",
          "description": "The user's email address"
        },
        "approved": {
          "type": "boolean",
          "description": "Whether the user is approved by an admin"
        },
        "role": {
          "type": "string",
          "description": "The user's role (admin or user)"
        },
        "createdAt": {
          "type": "number",
          "description": "When the user signed up"
        },
        "bio": {
          "type": "string",
          "description": "User's biography"
        },
        "points": {
          "type": "number",
          "description": "User's points balance"
        },
        "banned": {
          "type": "boolean",
          "description": "Whether the user is banned"
        },
        "muted": {
          "type": "boolean",
          "description": "Whether the user is muted"
        },
        "muteExpires": {
          "type": "number",
          "description": "When the mute expires"
        },
        "wishlist": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of game titles in wishlist"
        },
        "totalPlaytime": {
          "type": "number",
          "description": "Total playtime in seconds"
        },
        "gamesPlayed": {
          "type": "number",
          "description": "Number of unique games played"
        },
        "messagesSent": {
          "type": "number",
          "description": "Total messages sent in chat"
        },
        "favoriteGame": {
          "type": "string",
          "description": "The user's favorite game to show off"
        },
        "badges": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of badge IDs earned by the user"
        }
      },
      "required": ["username", "email", "approved", "role", "createdAt"]
    },
    "Rating": {
      "title": "Rating",
      "description": "A user's rating for a game",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "gameTitle": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "timestamp": { "type": "number" }
      },
      "required": ["uid", "gameTitle", "rating", "timestamp"]
    },
    "Suggestion": {
      "title": "Suggestion",
      "description": "A game suggestion or feedback",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["uid", "username", "text", "timestamp"]
    },
    "FriendRequest": {
      "title": "FriendRequest",
      "description": "A request to be friends",
      "type": "object",
      "properties": {
        "fromId": { "type": "string" },
        "fromName": { "type": "string" },
        "toId": { "type": "string" },
        "toName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "timestamp": { "type": "number" }
      },
      "required": ["fromId", "fromName", "toId", "toName", "status", "timestamp"]
    },
    "DirectMessage": {
      "title": "DirectMessage",
      "description": "A private message between two users",
      "type": "object",
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "number" },
        "participants": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["from", "to", "text", "timestamp", "participants"]
    },
    "UpdateLog": {
      "title": "UpdateLog",
      "description": "A system update log entry",
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "date": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["version", "date", "content", "timestamp"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages collection"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles collection"
    },
    "/friend_requests/{requestId}": {
      "schema": "FriendRequest",
      "description": "Friend requests collection"
    },
    "/dms/{messageId}": {
      "schema": "DirectMessage",
      "description": "Direct messages collection"
    },
    "/suggestions/{suggestionId}": {
      "schema": "Suggestion",
      "description": "Game suggestions collection"
    },
    "/ratings/{ratingId}": {
      "schema": "Rating",
      "description": "Game ratings collection"
    },
    "/update_logs/{logId}": {
      "schema": "UpdateLog",
      "description": "System update logs"
    }
  }
}
